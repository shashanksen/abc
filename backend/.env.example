# Copy to .env and edit. NEVER commit .env to git.
#
# This file uses the env-var secrets backend (SECRETS_BACKEND=env). Each
# logical secret is a JSON-encoded env var. In production, switch to
# SECRETS_BACKEND=aws-secrets-manager and these env vars become unused —
# values come from AWS Secrets Manager instead.

# ─── Backend selector ────────────────────────────────────────────────────────
SECRETS_BACKEND=env

# ─── Sensitive (JSON in env, dev only) ───────────────────────────────────────
CDP_DB_MAIN={"url":"postgresql+psycopg2://USER:PASS@HOST:5432/cdp"}
CDP_JWT_KEYS={"user_session":"change-me-to-a-long-random-string","agent_callback":"another-long-random-string"}

# Databricks OAuth (production only). Leave dummy values for local dev with mock.
CDP_DATABRICKS_OAUTH={"client_id":"dummy","client_secret":"dummy","token_endpoint":"https://accounts.cloud.databricks.com/oidc/accounts/CHANGE_ME/v1/token"}
CDP_DATABRICKS_AGENT_APP={"base_url":"http://localhost:8001","scope":"all-apis"}

# ─── Non-sensitive ───────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=*
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Agent-specific ──────────────────────────────────────────────────────────
AGENT_REQUEST_TIMEOUT_SECONDS=180
AGENT_DAILY_CHAR_BUDGET=500000

# Local-dev escape hatch: skip OAuth and use a static bearer (mock_agent.py).
# Comment out for prod.
AGENT_BEARER_OVERRIDE=dev-secret-not-for-prod
